# ------------------------------------------------------------------------
# Sealcraft configuration
# ------------------------------------------------------------------------
#
# Set SEALCRAFT_PROVIDER to one of: aws_kms | gcp_kms | azure_key_vault |
# vault_transit | local | config | null. Then uncomment and fill in the
# matching block below.
#
# `local` is fine for dev; production should use a real KMS.
# ------------------------------------------------------------------------

SEALCRAFT_PROVIDER=local
SEALCRAFT_CIPHER=aes-256-gcm
SEALCRAFT_DEK_STRATEGY=per_group
SEALCRAFT_CONTEXT_COLUMN=tenant_id
SEALCRAFT_CONTEXT_TYPE=tenant
SEALCRAFT_AUTO_REENCRYPT=true
SEALCRAFT_UNWRAP_RPM=1000
SEALCRAFT_VALIDATE_ON_BOOT=true
SEALCRAFT_DEK_CACHE_MAX_ENTRIES=1024

# ------------------------------------------------------------------------
# AWS KMS
# ------------------------------------------------------------------------
# SEALCRAFT_AWS_KEY_ID=alias/my-app-kek
# SEALCRAFT_AWS_REGION=us-east-1

# ------------------------------------------------------------------------
# GCP Cloud KMS (bind a token_resolver closure in a ServiceProvider)
# ------------------------------------------------------------------------
# SEALCRAFT_GCP_PROJECT=my-project
# SEALCRAFT_GCP_LOCATION=us-east1
# SEALCRAFT_GCP_KEY_RING=my-ring
# SEALCRAFT_GCP_CRYPTO_KEY=app-kek

# ------------------------------------------------------------------------
# Azure Key Vault (bind token_resolver and hmac_key_resolver for synthetic AAD)
# ------------------------------------------------------------------------
# SEALCRAFT_AZURE_VAULT_URL=https://my-vault.vault.azure.net
# SEALCRAFT_AZURE_KEY_NAME=app-kek
# SEALCRAFT_AZURE_AAD_STRATEGY=synthetic
# SEALCRAFT_AZURE_AAD_HMAC_KEY_NAME=sealcraft-aad-hmac

# ------------------------------------------------------------------------
# HashiCorp Vault Transit
# ------------------------------------------------------------------------
# SEALCRAFT_VAULT_ADDR=https://vault.internal:8200
# SEALCRAFT_VAULT_TOKEN=
# SEALCRAFT_VAULT_KEY_NAME=app-kek
# SEALCRAFT_VAULT_MOUNT=transit

# ------------------------------------------------------------------------
# Local file provider (dev/test only)
# ------------------------------------------------------------------------
SEALCRAFT_LOCAL_KEY_PATH=${STORAGE_PATH:-storage}/sealcraft/kek.key
SEALCRAFT_LOCAL_ALLOW_PRODUCTION=false

# ------------------------------------------------------------------------
# Config-backed KEK (env-injected key material; CI/CD populates)
# ------------------------------------------------------------------------
# SEALCRAFT_CONFIG_KEK_VERSION=v1
# SEALCRAFT_CONFIG_KEK_V1_B64=<base64 of 32 random bytes>
# SEALCRAFT_CONFIG_KEK_V2_B64=
# SEALCRAFT_CONFIG_KEK_V3_B64=
